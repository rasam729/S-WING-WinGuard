# ==============================================
# WinGuard - Environment Configuration Template
# ==============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ── Server ──────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── PostgreSQL Database (Neon Cloud recommended) ─
# Get a free DB at https://neon.tech
DB_HOST=your-neon-host.neon.tech
DB_PORT=5432
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=winguard
DB_SSL=true

# ── Authentication ───────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRATION=24h

# ── CORS Origins (comma-separated) ───────────────
CORS_ORIGIN=http://localhost:5178,http://localhost:5179,http://localhost:5173

# ── Geographic Center (Default: Bengaluru, India) ─
COORDINATE_CENTER_LAT=12.9716
COORDINATE_CENTER_LNG=77.5946
OPERATIONAL_RADIUS=5000

# ── File Upload ───────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# ── Safety Severity Weights ───────────────────────
SEVERITY_WEIGHT_USER=0.4
SEVERITY_WEIGHT_TYPE=0.3
SEVERITY_WEIGHT_TIME=0.2
SEVERITY_WEIGHT_CRIME=0.1

# ── Safe Routing Weights ──────────────────────────
POLICE_BOOTH_RADIUS=100
STREETLIGHT_RADIUS=50
DARK_SPOT_PENALTY=2.0
CRIME_ZONE_PENALTY=3.0

# ── Heatmap Configuration ─────────────────────────
DARK_SPOT_THRESHOLD=50
CRIME_ZONE_THRESHOLD=10
HEATMAP_RADIUS=200

# ── WebSocket Configuration ───────────────────────
WS_PING_INTERVAL=30000
WS_PING_TIMEOUT=5000

# ── Rate Limiting ─────────────────────────────────
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX_REQUESTS=100
