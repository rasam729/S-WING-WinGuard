{
  "name": "winguard-monorepo",
  "version": "1.0.0",
  "description": "WinGuard Urban Safety Platform - Monorepo",
  "private": true,
  "workspaces": [
    "apps/citizen-app",
    "apps/official-dashboard",
    "server",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:citizen\" \"npm run dev:official\"",
    "dev:server": "npm run dev --workspace=server",
    "dev:citizen": "npm run dev --workspace=apps/citizen-app",
    "dev:official": "npm run dev --workspace=apps/official-dashboard",
    "build": "npm run build --workspaces",
    "build:server": "npm run build --workspace=server",
    "build:citizen": "npm run build --workspace=apps/citizen-app",
    "build:official": "npm run build --workspace=apps/official-dashboard",
    "test": "npm run test --workspaces",
    "test:properties": "npm run test:properties --workspace=server",
    "test:integration": "npm run test:integration --workspace=server",
    "test:e2e": "playwright test",
    "test:coverage": "npm run test:coverage --workspaces",
    "lint": "npm run lint --workspaces",
    "clean": "npm run clean --workspaces && rm -rf node_modules",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:build": "docker-compose build",
    "docker:logs": "docker-compose logs -f"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "@playwright/test": "^1.40.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
