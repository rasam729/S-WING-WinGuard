# Server Configuration
NODE_ENV=development
PORT=3000

# ============================================
# PostgreSQL Database Configuration
# ============================================
# Choose ONE of the following options:

# OPTION 1: Cloud PostgreSQL (Neon, Supabase, Railway, Render)
# Recommended for production and Vercel/Render deployments
# DATABASE_URL=postgresql://username:password@host.region.provider.com:5432/dbname?sslmode=require

# OPTION 2: Local PostgreSQL (for development)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your-password-here
DB_NAME=inventory_db
DB_SSL=false

# ============================================
# Cloud Provider Examples:
# ============================================
# Neon: postgresql://user:pass@ep-xxx-xxx.us-east-2.aws.neon.tech/winguard?sslmode=require
# Supabase: postgresql://postgres:pass@db.xxx.supabase.co:5432/postgres
# Railway: postgresql://postgres:pass@containers-us-west-xxx.railway.app:5432/railway
# Render: postgresql://user:pass@dpg-xxx-a.oregon-postgres.render.com/dbname

# Authentication
JWT_SECRET=your-secret-key-here-change-in-production
JWT_EXPIRATION=24h

# Geographic Configuration (Default: New York City)
COORDINATE_CENTER_LAT=40.7128
COORDINATE_CENTER_LNG=-74.0060
OPERATIONAL_RADIUS=5000

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# Severity Weights
SEVERITY_WEIGHT_USER=0.4
SEVERITY_WEIGHT_TYPE=0.3
SEVERITY_WEIGHT_TIME=0.2
SEVERITY_WEIGHT_CRIME=0.1

# Routing Weights
POLICE_BOOTH_RADIUS=100
STREETLIGHT_RADIUS=50
DARK_SPOT_PENALTY=2.0
CRIME_ZONE_PENALTY=3.0

# Heatmap Configuration
DARK_SPOT_THRESHOLD=50
CRIME_ZONE_THRESHOLD=10
HEATMAP_RADIUS=200

# WebSocket Configuration
WS_PING_INTERVAL=30000
WS_PING_TIMEOUT=5000

# Rate Limiting
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX_REQUESTS=100

# CORS Origins (comma-separated)
CORS_ORIGIN=http://localhost:5173,http://localhost:5174
